{
  "entities": {
    "IntelligenceReport": {
      "title": "Intelligence Report",
      "description": "A life-saving intelligence analysis generated by Sentinel AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique report ID" },
        "userId": { "type": "string", "description": "UID of the user who generated the report" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the report was generated" },
        "input": { "type": "string", "description": "The raw unstructured input analyzed" },
        "summary": { "type": "string", "description": "High-level risk assessment summary" },
        "riskLevel": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"], "description": "Overall risk level" },
        "detectedContext": { "type": "string", "description": "The context detected by the AI" },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "priority": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
              "category": { "type": "string", "enum": ["MEDICAL", "ENVIRONMENTAL", "SECURITY", "LOGISTICS", "OTHER"] },
              "action": { "type": "string" },
              "verificationStatus": { "type": "string", "enum": ["VERIFIED", "PENDING", "UNVERIFIED"] },
              "reasoning": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "timestamp", "input", "summary", "riskLevel", "actions"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "IntelligenceReport",
      "description": "Collection of intelligence reports generated by users."
    }
  }
}
